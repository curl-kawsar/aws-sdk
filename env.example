# MinIO host ports (must match docker-compose). Raise if you see "address already in use".
MINIO_HOST_PORT_S3=29000
MINIO_HOST_PORT_CONSOLE=29001

# API host port (Nginx upstream must match)
API_HOST_PORT=29002

# MinIO credentials (change these in production!)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Default bucket name
MINIO_BUCKET=uploads

# Max upload size in megabytes
MAX_FILE_SIZE_MB=50

# Comma-separated allowed extensions (leave empty to allow all)
# Example: jpg,jpeg,png,gif,webp,pdf,doc,docx
ALLOWED_EXTENSIONS=

# true = upload /url return /files/.../download (no signature expiry; link works until file is deleted)
# false = presigned MinIO URLs (always expire; see PRESIGNED_URL_EXPIRES_HOURS, max 7 days in /url)
PERMANENT_DOWNLOAD_URLS=true

# Public API base for links in JSON, e.g. https://files.example.com (empty = use request Host)
PUBLIC_BASE_URL=

# Only when PERMANENT_DOWNLOAD_URLS=false (upload default uses this too)
PRESIGNED_URL_EXPIRES_HOURS=1

# --- Production hardening ---
# Comma-separated browser origins allowed to call the API (empty = * for local dev only)
# Example: https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=

# Host header allowlist (empty = disabled). Set to your public hostname and/or VPS IP.
# Example: files.example.com,203.0.113.10
TRUSTED_HOSTS=

# Comma-separated secrets; if set, every route except GET /health requires
# header X-API-Key: <one-of-keys> or Authorization: Bearer <key>
API_KEYS=

# Disable /docs, /redoc, /openapi.json in production (true recommended)
DISABLE_DOCS=true
